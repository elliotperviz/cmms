# Crystalline silicon 
#
pseudos "si.xml, b.xml"
#spgroup 227
#brvltt 0
chkprim 0
#tolsym 1e-6
chksymbreak 0
prtvol 1

#Definition of the unit cell
acell 1.0 1.0 1.0 Angstrom
rprim
     5.4437023729394527    0.0000000000000000    0.0000000000000000
     0.0000000000000000    5.4437023729394527    0.0000000000000000
     0.0000000000000000    0.0000000000000000    5.4437023729394527

#Definition of the atom types
ntypat 2          # There is only one type of atom
znucl 14 5        # The keyword "znucl" refers to the atomic number of the 
                  # possible type(s) of atom. The pseudopotential(s) 
                  # mentioned in the "files" file must correspond
                  # to the type(s) of atom. Here, the only type is Silicon.

#Definition of the atoms
natom 8           # There are two atoms
typat 7*1 1*2         # They both are of type 1, that is, Silicon.
xred
  0.2500000000000000  0.7500000000000000  0.7500000000000000
  0.0000000000000000  0.0000000000000000  0.0000000000000000
  0.2500000000000000  0.2500000000000000  0.2500000000000000
  0.0000000000000000  0.5000000000000000  0.5000000000000000
  0.7500000000000000  0.7500000000000000  0.2500000000000000
  0.5000000000000000  0.0000000000000000  0.5000000000000000
  0.7500000000000000  0.2500000000000000  0.7500000000000000
  0.5000000000000000  0.5000000000000000  0.0000000000000000

#Definition of the planewave basis set
ecut  500 eV         # Maximal kinetic energy cut-off, in Hartree
pawecutdg 500 eV

#Definition of the k-point grid
kptopt 1          # Option for the automatic generation of k points, taking
                  # into account the symmetry
ngkpt 3 3 3       # This is a 3x3x3 grid based on the primitive vectors

#Definition of the SCF procedure
nstep 20          # Maximal number of SCF cycles
diemac 12.0       # Although this is not mandatory, it is worth to
                  # precondition the SCF cycle. The model dielectric
                  # function used as the standard preconditioner
                  # is described in the "dielng" input variable section.
                  # Here, we follow the prescription for bulk silicon.
nband 32

ndtset 3 jdtset  1 2 4

#DATASET 1: geometry optimization
#################################
 dilatmx1  1.1
 optcell1  2
 ionmov1   2
 ecutsm1   0.5
 ntime1    300
 tolmxf1   5.0d-5
 toldfe1   1.0d-6
 prtwf     1

#DATASET 2 : scf calculation: GS WF in the BZ
#********************************************
#   getcell2   1
#   getxcart2  1
#   getwfk2    1
   toldfe2    1.0d-6
   prtden2    1
   prtwf2     1

#DATASET 3 : non scf calculation: GS WF in the whole BZ
#*****************************************************
#   getcell3   1
#   getxcart3  1
   getden3    2
   getwfk3    2
     iscf3   -2            # Non-SCF calculation, read density and compute at specified k-points for a fixed potential
   tolwfr3    1.0d-10      # Convergence tolerance for largest squared residual over all bands and k-points
   kptopt3    3            # Full k-point grid, no symmetry reductions
dosdeltae3    0.0069986 eV # Linear grid resolution (energy increment) for computation of DOS (non-zero prtdos)
   prtdos3    2            # Total DOS
#  prtdosm3    1            # Also, activate m-decomposition (l,m unique states)

#DATASET 4 : Electronic Band Structure
#********************************************
#  getcell4  1
#  getxcart4 1
  pawfatbnd4 1
  getden4   2
  getwfk4   2
  iscf4     -2
  tolwfr4   1.0d-10
  kptopt4   -11            # kptopt < 0 specifies non-SCF BS calculation, and abs(kptopt) gives number of segments
  ndivsm4   10             # number of divisions of the smallest segment of the high symmetry path
  kptbounds4               # Specify the high symmetry path in the BZ 
   0.0000   0.0000   0.0000   ! \Gamma
   0.5000   0.0000   0.5000   ! X
   0.5000   0.2500   0.7500   ! W
   0.3750   0.3750   0.7500   ! K
   0.0000   0.0000   0.0000   ! \Gamma
   0.5000   0.5000   0.5000   ! L
   0.6250   0.2500   0.6250   ! U
   0.5000   0.2500   0.7500   ! W
   0.5000   0.5000   0.5000   ! L
   0.3750   0.3750   0.7500   ! K
   0.6250   0.2500   0.6250   ! U
   0.5000   0.0000   0.5000   ! X

